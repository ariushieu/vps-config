# ========================================
# Environment variables (Example Template)
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ========================================

# --- MongoDB ---
MONGO_USERNAME=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DATABASE=your_database_name

# --- Node.js App ---
NODE_ENV=production
PORT=3000
MONGO_URI=mongodb://${MONGO_USERNAME}:${MONGO_PASSWORD}@mongo:27017/${MONGO_DATABASE}?authSource=admin

# --- JWT ---
# JWT_SECRET=your_jwt_secret

# --- Other ---
# API_KEY=your_api_key

# --- Timezone (must match host tz from setup_vps.sh Step 11) ---
# Applied to both app + mongo containers via docker-compose
#   Vietnam   -> TZ=Asia/Ho_Chi_Minh
#   Singapore -> TZ=Asia/Singapore
#   UTC       -> TZ=UTC
# Note: MongoDB always stores dates in UTC; TZ only affects container logs.
TZ=UTC
