# ========================================
# Environment variables (Example Template)
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ========================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# --- Spring Boot App ---
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/your_database_name?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# --- Email (SMTP / Resend) ---
# RESEND_API_KEY=your_resend_api_key

# --- JWT ---
# JWT_SECRET=your_jwt_secret

# --- Timezone (must match host tz from setup_vps.sh Step 11) ---
# TZ        : IANA name, applied to app + mysql containers
# MYSQL_TZ_OFFSET : numeric offset for MySQL --default-time-zone
#   Vietnam   -> TZ=Asia/Ho_Chi_Minh   MYSQL_TZ_OFFSET=+07:00
#   Singapore -> TZ=Asia/Singapore     MYSQL_TZ_OFFSET=+08:00
#   UTC       -> TZ=UTC                MYSQL_TZ_OFFSET=+00:00
TZ=UTC
MYSQL_TZ_OFFSET=+00:00
